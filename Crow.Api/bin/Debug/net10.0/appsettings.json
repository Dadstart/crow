{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Encryption": {
    "MasterKey": "ChangeThisToASecureMasterKeyInProduction"
  },
  "Jwt": {
    "SecretKey": "ChangeThisToASecureSecretKeyAtLeast32CharactersLong",
    "Issuer": "CrowApi",
    "Audience": "CrowApp",
    "ExpirationMinutes": "1440"
  }
}
