<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Crow.Models"
             x:Class="Crow.Views.TaskListPage"
             x:Name="ThisPage"
             Title="Tasks">

    <!-- Grid: header row (Auto) + list (* fills remaining viewport height). -->
    <Grid Padding="{OnIdiom Phone='16', Tablet='24', Desktop='32'}"
          MaximumWidthRequest="{OnIdiom Phone='800', Tablet='980', Desktop='1280'}"
          HorizontalOptions="Center"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Button Grid.Column="1"
                    Padding="16,10"
                    Clicked="OnAddClicked"
                    HorizontalOptions="End"
                    SemanticProperties.Hint="Create a new task"
                    Text="Add task" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tasks}"
                        SelectionMode="None"
                        VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="{OnIdiom Phone='1', Tablet='2', Desktop='3'}"
                                 VerticalItemSpacing="10"
                                 HorizontalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TaskItem">
                    <!-- Row: flexible title/description (*), intrinsic-width actions (Auto). -->
                    <Border Padding="10"
                            StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10"
                              RowDefinitions="Auto,Auto">
                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.RowSpan="2"
                                                 Grid.Column="0"
                                                 Spacing="4">
                                <Label FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"
                                       Text="{Binding Title}" />
                                <Label FontSize="13"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="3"
                                       Text="{Binding Description}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                               Dark={StaticResource Gray300}}" />
                            </VerticalStackLayout>
                            <Button Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Clicked="OnEditClicked"
                                    SemanticProperties.Hint="Edit this task"
                                    Text="Edit"
                                    VerticalOptions="Center" />
                            <Button Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="2"
                                    Command="{Binding Path=ToggleCompletionCommand, Source={x:Reference ThisPage}}"
                                    CommandParameter="{Binding .}"
                                    SemanticProperties.Hint="Mark task complete or incomplete"
                                    Text="Done"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
