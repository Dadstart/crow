<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Crow.Views.ThemeSettingsPage"
             Title="Appearance">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="8">
            <Label FontAttributes="Bold"
                   Text="Theme" />
            <Label Opacity="0.75"
                   Text="Choose whether crow follows your device theme or stays light or dark. This applies everywhere in the app." />
            <Picker Title="App theme"
                    ItemsSource="{Binding ThemeOptions}"
                    SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                    SemanticProperties.Hint="Select light, dark, or match the system theme" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
