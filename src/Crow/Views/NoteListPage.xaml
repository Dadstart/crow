<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Crow.Models"
             x:Class="Crow.Views.NoteListPage"
             Title="Notes">

    <Grid Padding="{OnIdiom Phone='16', Tablet='24', Desktop='32'}"
          MaximumWidthRequest="{OnIdiom Phone='800', Tablet='980', Desktop='1280'}"
          HorizontalOptions="Center"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Button Grid.Column="1"
                    Padding="16,10"
                    Clicked="OnAddClicked"
                    HorizontalOptions="End"
                    SemanticProperties.Hint="Create a new note"
                    Text="Add note" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notes}"
                        SelectionMode="None"
                        VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="{OnIdiom Phone='1', Tablet='2', Desktop='3'}"
                                 VerticalItemSpacing="10"
                                 HorizontalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NoteItem">
                    <Border Padding="10"
                            StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="4">
                                <Label FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"
                                       Text="{Binding Title}" />
                                <Label FontSize="13"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="3"
                                       Text="{Binding Content}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                               Dark={StaticResource Gray300}}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Clicked="OnEditClicked"
                                    SemanticProperties.Hint="Edit this note"
                                    Text="Edit"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
