<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Crow.Models"
             x:Class="Crow.Views.NoteListPage"
             Title="Notes">

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Button Grid.Column="1"
                    Padding="16,10"
                    Clicked="OnAddClicked"
                    HorizontalOptions="End"
                    SemanticProperties.Hint="Create a new note"
                    Text="Add note" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notes}"
                        SelectionMode="None"
                        VerticalOptions="Fill">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NoteItem">
                    <Grid Padding="4,10"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="4">
                            <Label FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   Text="{Binding Title}" />
                            <Label FontSize="13"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="3"
                                   Text="{Binding Content}"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                               Dark={StaticResource Gray300}}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Padding="14,10"
                                Clicked="OnEditClicked"
                                SemanticProperties.Hint="Edit this note"
                                Text="Edit"
                                VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
