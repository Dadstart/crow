<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Crow.ViewModels"
             x:Class="Crow.Views.TaskDetailPage"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="OnSaveClicked"
                     Order="Primary"
                     Priority="0"
                     Text="Save" />
        <ToolbarItem Clicked="OnDeleteClicked"
                     Order="Secondary"
                     Priority="1"
                     Text="Delete" />
    </ContentPage.ToolbarItems>

    <!-- ScrollView keeps the form usable in short windows and on phones. -->
    <ScrollView>
        <Grid Padding="{OnIdiom Phone='16', Tablet='24', Desktop='32'}"
              HorizontalOptions="Center"
              MaximumWidthRequest="{OnIdiom Phone='720', Tablet='900', Desktop='1100'}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="{OnIdiom Phone='*', Tablet='*,*', Desktop='*,*'}"
                  ColumnSpacing="{OnIdiom Phone='0', Tablet='16', Desktop='20'}"
                  RowSpacing="14">
                <Entry Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                       Placeholder="Title"
                       SemanticProperties.Hint="Task title"
                       Text="{Binding CurrentTask.Title}" />

                <Editor Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                        AutoSize="TextChanges"
                        Placeholder="Description"
                        SemanticProperties.Hint="Task description"
                        Text="{Binding CurrentTask.Description}" />

                <!-- Completed + due-date controls are grouped to keep related fields together. -->
                <VerticalStackLayout Grid.Row="2"
                                     Grid.Column="0"
                                     Spacing="10">
                    <FlexLayout AlignItems="Center"
                                Direction="Row"
                                JustifyContent="SpaceBetween"
                                Wrap="Wrap">
                        <Label SemanticProperties.Hint="Whether the task is completed"
                               Text="Completed"
                               VerticalTextAlignment="Center" />
                        <Switch IsToggled="{Binding CurrentTask.IsCompleted}"
                                SemanticProperties.Hint="Toggle task completed" />
                    </FlexLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding HasDueDate}"
                                  SemanticProperties.Hint="Toggle optional due date" />
                        <Label Text="Has due date"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2"
                                     Grid.Column="{OnIdiom Phone='0', Tablet='1', Desktop='1'}"
                                     IsVisible="{OnIdiom Phone='False', Tablet='True', Desktop='True'}"
                                     Spacing="10">
                    <Picker Title="Priority"
                            ItemsSource="{x:Static vm:TaskDetailViewModel.PriorityOptions}"
                            SemanticProperties.Hint="Task priority"
                            SelectedIndex="{Binding CurrentTask.Priority}" />
                    <DatePicker Date="{Binding DueDatePickerValue}"
                                Format="yyyy-MM-dd"
                                IsEnabled="{Binding HasDueDate}"
                                SemanticProperties.Hint="Task due date" />
                </VerticalStackLayout>

                <Picker Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                        IsVisible="{OnIdiom Phone='True', Tablet='False', Desktop='False'}"
                        Title="Priority"
                        ItemsSource="{x:Static vm:TaskDetailViewModel.PriorityOptions}"
                        SemanticProperties.Hint="Task priority"
                        SelectedIndex="{Binding CurrentTask.Priority}" />

                <DatePicker Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                            IsVisible="{OnIdiom Phone='True', Tablet='False', Desktop='False'}"
                            Date="{Binding DueDatePickerValue}"
                            Format="yyyy-MM-dd"
                            IsEnabled="{Binding HasDueDate}"
                            SemanticProperties.Hint="Task due date" />

                <Entry Grid.Row="{OnIdiom Phone='5', Tablet='3', Desktop='3'}"
                       Grid.Column="0"
                       Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                       Placeholder="Tags (comma-separated)"
                       SemanticProperties.Hint="Comma separated tags"
                       Text="{Binding TagsText}" />
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
