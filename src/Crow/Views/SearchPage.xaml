<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Crow.Models"
             x:Class="Crow.Views.SearchPage"
             Title="Search">

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
            <SearchBar Grid.Column="0"
                       Placeholder="Search tasks and notes…"
                       SearchButtonPressed="OnSearchButtonPressed"
                       SemanticProperties.Hint="Search by title or content"
                       Text="{Binding QueryText, Mode=TwoWay}" />
            <Button Grid.Column="1"
                    Padding="14,10"
                    Command="{Binding SearchCommand}"
                    SemanticProperties.Hint="Run search"
                    Text="Search"
                    VerticalOptions="Center" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Results}"
                        SelectionChanged="OnResultSelectionChanged"
                        SelectionMode="Single"
                        VerticalOptions="Fill">
            <CollectionView.EmptyView>
                <Label HorizontalOptions="Center"
                       Opacity="0.6"
                       Text="No results yet. Enter text and tap Search."
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SearchResultItem">
                    <Grid Padding="4,12"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="10"
                          RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Padding="6,2"
                               BackgroundColor="{AppThemeBinding Light=#E8E8E8,
                                                               Dark=#3A3A3A}"
                               FontSize="12"
                               Text="{Binding KindLabel}"
                               VerticalOptions="Start" />
                        <Label Grid.Row="0"
                               Grid.Column="1"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="2"
                               Text="{Binding Title}"
                               VerticalOptions="Start" />
                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="13"
                               LineBreakMode="TailTruncation"
                               MaxLines="3"
                               Text="{Binding Preview}"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                           Dark={StaticResource Gray400}}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
