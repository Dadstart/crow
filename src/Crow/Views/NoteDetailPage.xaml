<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Crow.Views.NoteDetailPage"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="OnSaveClicked"
                     Order="Primary"
                     Priority="0"
                     Text="Save" />
        <ToolbarItem Clicked="OnDeleteClicked"
                     Order="Secondary"
                     Priority="1"
                     Text="Delete" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid Padding="{OnIdiom Phone='16', Tablet='24', Desktop='32'}"
              HorizontalOptions="Center"
              MaximumWidthRequest="{OnIdiom Phone='720', Tablet='900', Desktop='1100'}">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="{OnIdiom Phone='*', Tablet='2*,*', Desktop='2*,*'}"
                  ColumnSpacing="{OnIdiom Phone='0', Tablet='16', Desktop='20'}"
                  RowSpacing="14">
                <Entry Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="{OnIdiom Phone='1', Tablet='2', Desktop='2'}"
                       Placeholder="Title"
                       SemanticProperties.Hint="Note title"
                       Text="{Binding CurrentNote.Title}" />

                <Editor Grid.Row="1"
                        Grid.Column="0"
                        AutoSize="TextChanges"
                        Placeholder="Content"
                        SemanticProperties.Hint="Note body"
                        Text="{Binding CurrentNote.Content}" />

                <Entry Grid.Row="{OnIdiom Phone='2', Tablet='1', Desktop='1'}"
                       Grid.Column="{OnIdiom Phone='0', Tablet='1', Desktop='1'}"
                       Placeholder="Tags (comma-separated)"
                       SemanticProperties.Hint="Comma separated tags"
                       Text="{Binding TagsText}" />
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
