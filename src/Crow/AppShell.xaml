<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Crow.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Crow.Views"
    Title="crow">

    <TabBar>
        <ShellContent
            Title="Search"
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="SearchPage" />
        <ShellContent
            Title="Tasks"
            ContentTemplate="{DataTemplate views:TaskListPage}"
            Route="TaskListPage" />
        <ShellContent
            Title="Notes"
            ContentTemplate="{DataTemplate views:NoteListPage}"
            Route="NoteListPage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:ThemeSettingsPage}"
            Route="ThemeSettingsPage" />
    </TabBar>

</Shell>