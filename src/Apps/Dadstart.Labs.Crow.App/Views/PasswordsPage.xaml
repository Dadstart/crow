<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dadstart.Labs.Crow.Views.PasswordsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Dadstart.Labs.Crow.ViewModels"
    xmlns:models="clr-namespace:Dadstart.Labs.Crow.Models;assembly=Dadstart.Labs.Crow.Core"
    x:DataType="viewmodels:PasswordsViewModel"
    Title="Passwords">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Add"
            Command="{Binding AddCredentialCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
        <SearchBar
            Placeholder="Search"
            Text="{Binding SearchQuery}"
            SearchCommand="{Binding RefreshCommand}" />

        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Passwords}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PasswordEntry">
                        <Border
                            Padding="12"
                            Margin="8"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout>
                                <Label
                                    Text="{Binding Title}"
                                    FontAttributes="Bold"
                                    FontSize="18" />
                                <Label Text="{Binding Username}" FontAttributes="Italic" />
                                <Label
                                    Text="••••••••"
                                    FontFamily="monospace"
                                    TextColor="{AppThemeBinding Light='DarkGreen', Dark='#90ee90'}" />
                                <Label
                                    Text="{Binding UpdatedAt, StringFormat='Updated {0:g}'}"
                                    FontSize="12"
                                    TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>

