<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Dadstart.Labs.Crow.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Dadstart.Labs.Crow.Views"
    Title="Crow Vault"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Route="vault">
        <ShellContent
            Title="Notes"
            ContentTemplate="{DataTemplate views:NotesPage}"
            Route="notes" />
        <ShellContent
            Title="Passwords"
            ContentTemplate="{DataTemplate views:PasswordsPage}"
            Route="passwords" />
        <ShellContent
            Title="Reminders"
            ContentTemplate="{DataTemplate views:RemindersPage}"
            Route="reminders" />
    </TabBar>

</Shell>
