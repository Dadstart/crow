<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dadstart.Labs.Crow.App.Pages.PasswordsPage"
             x:DataType="viewModels:PasswordsPageViewModel"
             xmlns:viewModels="clr-namespace:Dadstart.Labs.Crow.App.ViewModels"
             xmlns:dtos="clr-namespace:Dadstart.Labs.Crow.Models.Dtos;assembly=Crow.Models"
             Title="Passwords">
    <Grid RowDefinitions="Auto,*" Padding="10">
        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="10">
            <Entry Text="{Binding Title}" Placeholder="Title" />
            <Entry Text="{Binding Username}" Placeholder="Username" />
            <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" />
            <Entry Text="{Binding Url}" Placeholder="URL (optional)" Keyboard="Url" />
            <Editor Text="{Binding Notes}" Placeholder="Notes (optional)" HeightRequest="60" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" 
                        Text="Create"
                        Command="{Binding CreatePasswordCommand}" />
                <Button Grid.Column="1" 
                        Text="Update"
                        Command="{Binding UpdatePasswordCommand}"
                        CommandParameter="{Binding SelectedPassword}" />
            </Grid>
            <Button Text="Clear Selection" 
                    Command="{Binding ClearSelectionCommand}" />
        </VerticalStackLayout>
        
        <RefreshView Grid.Row="1" 
                     IsRefreshing="{Binding IsLoading}"
                     Command="{Binding LoadPasswordsCommand}">
            <CollectionView ItemsSource="{Binding Passwords}" SelectionMode="Single" SelectionChanged="OnPasswordSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dtos:PasswordResponseDto">
                        <Grid Padding="10" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding Username}" />
                                <Label Text="{Binding Url}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" 
                                    Text="Delete"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:PasswordsPageViewModel}}, Path=DeletePasswordCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
